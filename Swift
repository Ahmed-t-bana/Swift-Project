let currentEnrollment = Enrollment(enrollmentId: 7001, semester: "Spring 2026", grade: "B+", student: s1, course: c1)
s1.enrollments.append(currentEnrollment)

let hw1 = Assignment(id: 401, title: "Swift Basics Homework", dueDate: Date())
c1.assignments.append(hw1)

let sub1 = Submission(id: 501, fileName: "assignment1.swift", submittedAt: Date())
